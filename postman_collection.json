{
	"info": {
		"_postman_id": "1a2b3c4d-5e6f-7g8h-9i0j",
		"name": "Antigravity API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Admin Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@antigravity.com\",\n    \"password\": \"admin123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/admin/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"admin",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Generate Client User Token",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"app_id\": \"app_example\",\n    \"public_key\": \"pk_example\",\n    \"secret_key\": \"sk_example\",\n    \"external_user_id\": \"test_user_1\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"token"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Tenant",
			"item": [
				{
					"name": "Create Conversation",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"one-to-one\",\n    \"participant_external_ids\": [\"test_user_2\"]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/tenant/conversations",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tenant",
								"conversations"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000/api/v1"
		},
		{
			"key": "jwt_token",
			"value": "your_token_here"
		}
	]
}
